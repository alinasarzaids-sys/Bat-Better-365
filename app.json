{
  "expo": {
    "name": "Bat Better 365",
    "slug": "batbetter365",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "batbetter365",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E1E1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.batbetter365.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Live Lab uses the camera as a biomechanical sensor to measure head position, footwork and bat angle for AI coaching analysis.",
        "NSMicrophoneUsageDescription": "Microphone is used when recording batting footage for AI swing analysis.",
        "NSPhotoLibraryUsageDescription": "Gallery access lets you upload recorded batting footage to the AI coaching engine for Technical Balance Reports."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E20"
      },
      "package": "com.batbetter365.app",
      "versionCode": 1774805629,
      "targetSdkVersion": 34,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/exclude-expo-video"
    ]
  }
}
